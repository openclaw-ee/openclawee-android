<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="24dp">

    <!-- App title -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/titleText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="@color/text_primary"
        android:textSize="22sp"
        android:letterSpacing="0.05"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/settingsButton"
        android:layout_marginTop="32dp" />

    <!-- Settings gear button (top-right) -->
    <ImageButton
        android:id="@+id/settingsButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@android:drawable/ic_menu_manage"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:tint="@color/text_secondary"
        android:contentDescription="Settings"
        app:layout_constraintTop_toTopOf="@id/titleText"
        app:layout_constraintBottom_toBottomOf="@id/titleText"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Models missing warning card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/modelsWarningCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:cardBackgroundColor="@color/surface_variant"
        app:cardCornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/titleText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/models_missing_title"
                android:textColor="@color/warning"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium" />

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/models_missing_body"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="8dp"
                android:lineSpacingMultiplier="1.4" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Conversation history header row (label + clear button) -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/historyLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Conversation"
        android:textSize="11sp"
        android:textColor="@color/text_secondary"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        app:layout_constraintTop_toBottomOf="@id/modelsWarningCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/clearHistoryButton"
        android:layout_marginTop="16dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/clearHistoryButton"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Clear"
        android:textSize="11sp"
        android:textColor="@color/text_secondary"
        android:minHeight="0dp"
        android:paddingTop="0dp"
        android:paddingBottom="0dp"
        app:layout_constraintTop_toTopOf="@id/historyLabel"
        app:layout_constraintBottom_toBottomOf="@id/historyLabel"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Conversation history RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/conversationRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/historyLabel"
        app:layout_constraintBottom_toTopOf="@id/waveformView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="16dp" />

    <!-- Waveform visualizer -->
    <ai.openclaw.voice.ui.WaveformView
        android:id="@+id/waveformView"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/micButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="32dp" />

    <!-- Status text -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/status_idle"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        app:layout_constraintBottom_toTopOf="@id/micButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="12dp" />

    <!-- Mic button (large circular FAB) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/micButton"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:src="@drawable/ic_mic"
        app:fabCustomSize="96dp"
        app:maxImageSize="48dp"
        app:backgroundTint="@color/mic_button_bg"
        app:tint="@color/mic_button_icon"
        app:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="64dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
